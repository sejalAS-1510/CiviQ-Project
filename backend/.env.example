# CiviQ Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/civiq
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/civiq

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=7d

# ==================== EMAIL SERVICE (GMAIL) ====================
# Gmail configuration using App Password (not regular password)
# 
# Steps to set up Gmail App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Sign in with your Google account
# 3. Select "Mail" and "Windows Computer" (or your device)
# 4. Google will generate a 16-character app-specific password
# 5. Copy the password and paste it below (remove spaces)
#
# Example: if Google gives you "abcd efgh ijkl mnop"
# Use as: GMAIL_APP_PASSWORD=abcdeFghijklmnop

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# ==================== FRONTEND URL ====================
# Used in email links to direct users back to your app
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://yourdomain.com

# ==================== SERVER ====================
PORT=5000
NODE_ENV=development
# For production: NODE_ENV=production

# ==================== OPTIONAL: GOOGLE CALENDAR ====================
# For Google Calendar integration (implement in next phase)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key

# ==================== LOGGING ====================
LOG_LEVEL=debug
# Options: debug, info, warn, error
