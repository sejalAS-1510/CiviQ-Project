# Copy this file to backend/.env and fill in real values. DO NOT commit your real .env to git.

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/civiq?retryWrites=true&w=majority

# JWT secret used to sign tokens (generate a long random string)
JWT_SECRET=replace_with_random_secret

# Email provider: gmail, sendgrid, or brevo
EMAIL_PROVIDER=gmail

# If using Gmail with app password
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
# GMAIL_PASS=your_16_character_app_password  # supported for compatibility

# If using SendGrid instead
# SENDGRID_API_KEY=replace_with_sendgrid_api_key
# SENDGRID_FROM_EMAIL=verified-sender@example.com

# If using Brevo SMTP instead
# EMAIL_USER=your_brevo_smtp_user
# EMAIL_PASS=your_brevo_smtp_password

# Frontend origin — for Vite dev server default is http://localhost:5173
# If you use `npm run dev:single` (backend serves built frontend), set to backend origin, e.g. http://localhost:8080
# If deploying frontend separately, set your live frontend URL here
FRONTEND_URL=http://localhost:5173
