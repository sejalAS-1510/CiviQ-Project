# CiviQ Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== DATABASE ====================
MONGODB_URI=mongodb://localhost:27017/civiq
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/civiq

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=7d

# ==================== EMAIL SERVICE PROVIDER ====================
# Choose your email provider:
# EMAIL_PROVIDER=sendgrid  (RECOMMENDED for production - most reliable)
# EMAIL_PROVIDER=gmail     (Good for development - requires App Password)

EMAIL_PROVIDER=sendgrid

# ==================== SENDGRID CONFIGURATION (RECOMMENDED) ====================
# SendGrid is cloud-based, production-ready email service
# Free tier: 100 emails/day forever
# Production tier: Unlimited emails (from $19.95/month)
#
# Steps to set up SendGrid:
# 1. Sign up free at https://sendgrid.com/pricing
# 2. Go to Settings → API Keys → Create API Key
# 3. Choose "Restricted Access" (better security)
# 4. Enable: Mail Send (Full Access), Mail Send Settings (Read)
# 5. Copy the API key and paste below
# 6. Verify your sender email in Sender Verification settings

SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
SENDGRID_FROM_NAME=CiviQ Support

# ==================== GMAIL CONFIGURATION (ALTERNATIVE - Development Only) ====================
# Only used if EMAIL_PROVIDER=gmail
# Gmail configuration using App Password (not regular password)
# 
# Steps to set up Gmail App Password:
# 0. Enable 2-Step Verification on your Google account
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Sign in with your Google account
# 3. Select "Mail" and "Windows Computer" (or your device)
# 4. Google will generate a 16-character app-specific password
# 5. Copy the password and paste it below (remove spaces)
#
# Example: if Google gives you "abcd efgh ijkl mnop"
# Use as: GMAIL_APP_PASSWORD=abcdefghijklmnop

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here
EMAIL_FROM="CiviQ Support <your-email@gmail.com>"

# Email delivery reliability settings
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=1500
EMAIL_SEND_TIMEOUT_MS=10000

# ==================== EMAIL DELIVERY SETTINGS ====================
# Reliability settings for email retries
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_MS=1500
EMAIL_SEND_TIMEOUT_MS=10000

# ==================== FRONTEND URL ====================
# Used in email links to direct users back to your app
FRONTEND_URL=http://localhost:8080
# For production:
# FRONTEND_URL=https://yourdomain.com

# ==================== SERVER ====================
PORT=5000
NODE_ENV=development
# For production: NODE_ENV=production

# ==================== OPTIONAL: GOOGLE CALENDAR ====================
# For Google Calendar integration (implement in next phase)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key

# ==================== LOGGING ====================
LOG_LEVEL=debug
# Options: debug, info, warn, error
